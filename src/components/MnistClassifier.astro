---
interface Props {
  apiUrl?: string;
}

const { apiUrl = '/api/predict' } = Astro.props;
---

<main class="min-h-screen bg-fog px-5 py-6 text-ink sm:px-8 lg:px-10">
  <section class="mx-auto flex min-h-[calc(100vh-3rem)] max-w-6xl flex-col gap-8">
    <header class="flex flex-col gap-5 border-b border-line pb-6 md:flex-row md:items-end md:justify-between">
      <div class="max-w-3xl">
        <p class="text-xs font-semibold uppercase tracking-[0.24em] text-accent">Desarrollado por Wilmer Parra</p>
        <h1 class="mt-3 text-4xl font-semibold text-center leading-tight tracking-normal text-ink sm:text-5xl">
          Reconocimiento de dígitos <br> Modelo neuronal
        </h1>
      </div>
      <p class="max-w-sm text-sm leading-6 text-slate-500">
        Sube solo una imagen. El modelo devuelve la clase detectada y la distribucion de confianza.
      </p>
    </header>

    <div class="grid flex-1 gap-6 lg:grid-cols-[0.85fr_1.15fr]">
      <form
        id="upload-form"
        class="flex flex-col justify-between rounded-[8px] border border-line bg-white p-4 shadow-soft"
      >
        <label
          id="drop-zone"
          for="file-input"
          class="flex min-h-[300px] cursor-pointer flex-col items-center justify-center gap-6 rounded-[8px] border border-dashed border-slate-300 bg-slate-50/70 px-6 py-10 text-center transition hover:border-accent hover:bg-white"
        >
          <span class="grid h-14 w-14 place-items-center rounded-[8px] bg-ink text-white shadow-soft">
            <svg viewBox="0 0 24 24" class="h-7 w-7" fill="none" aria-hidden="true">
              <path
                d="M12 16V4m0 0 4.5 4.5M12 4 7.5 8.5M5 16.5V19a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-2.5"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
              />
            </svg>
          </span>

          <span class="space-y-2">
            <strong class="block text-2xl font-semibold text-ink">Arrastra una imagen</strong>
            <span class="block text-sm text-slate-500">PNG, JPG o WEBP</span>
          </span>

          <span class="inline-flex h-10 items-center rounded-[8px] border border-line bg-white px-4 text-sm font-semibold text-ink transition hover:border-accent hover:text-accent">
            Seleccionar imagen
          </span>

          <input id="file-input" name="files" type="file" accept="image/*" class="sr-only" />
        </label>

        <div id="preview-panel" class="mt-4 hidden rounded-[8px] border border-line bg-fog p-3">
          <div class="mb-3 flex items-center justify-between gap-3">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Imagen cargada</p>
            <button
              id="clear-button"
              type="button"
              class="text-sm font-semibold text-slate-500 transition hover:text-accent"
            >
              Limpiar
            </button>
          </div>
          <div id="preview-list" class="grid grid-cols-3 gap-3 sm:grid-cols-4"></div>
        </div>

        <div class="mt-4 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
          <p id="file-summary" class="text-sm text-slate-500">Ningun archivo seleccionado.</p>
          <div class="grid grid-cols-2 gap-2 sm:flex">
            <button
              id="reset-button"
              type="button"
              class="inline-flex h-11 items-center justify-center rounded-[8px] border border-line bg-white px-5 text-sm font-semibold text-ink transition hover:border-accent hover:text-accent"
            >
              Resetear
            </button>
            <button
              id="submit-button"
              type="submit"
              class="inline-flex h-11 items-center justify-center rounded-[8px] bg-ink px-5 text-sm font-semibold text-white transition hover:bg-accent disabled:cursor-not-allowed disabled:bg-slate-300"
              disabled
            >
              Analizar
            </button>
          </div>
        </div>
      </form>

      <section class="rounded-[8px] border border-line bg-white p-4 shadow-soft sm:p-6">
        <div class="flex items-center justify-between gap-4">
          <div>
            <h2 class="text-lg font-semibold">Resultados</h2>
            <p id="status-text" class="mt-1 text-sm text-slate-500">Listo para analizar.</p>
          </div>
          <div id="loader" class="hidden h-9 w-9 rounded-full border-2 border-slate-200 border-t-accent"></div>
        </div>

        <div id="empty-state" class="grid min-h-[520px] place-items-center text-center">
          <div class="space-y-4">
            <div class="mx-auto grid h-28 w-28 place-items-center rounded-[8px] border border-line bg-fog">
              <span class="text-5xl font-semibold text-slate-300">7</span>
            </div>
            <p class="max-w-xs text-sm leading-6 text-slate-500">
              La prediccion aparecera aqui con una lectura compacta de probabilidades.
            </p>
          </div>
        </div>

        <div id="results-grid" class="mt-6 grid gap-4"></div>
      </section>
    </div>
  </section>
</main>

<footer class="mx-auto mt-8 max-w-6xl rounded-[8px] border border-line bg-white px-4 py-4 text-center text-sm text-slate-500 shadow-soft sm:px-6">
  <div class="flex flex-col items-center justify-center gap-3 sm:flex-row sm:justify-center sm:gap-4">
    <span>© 2026 Wilmer Parra.</span>
    <a
      href="https://github.com/WilmerParra21/pyNumber_ia"
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-2 text-ink transition hover:text-accent"
    >
      <svg viewBox="0 0 24 24" class="h-4 w-4 fill-current" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
        <path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.438 9.8 8.205 11.385.6.113.82-.263.82-.582 0-.288-.01-1.05-.015-2.06-3.338.725-4.042-1.61-4.042-1.61-.546-1.387-1.333-1.757-1.333-1.757-1.09-.745.082-.73.082-.73 1.205.085 1.84 1.237 1.84 1.237 1.07 1.835 2.807 1.305 3.492.998.108-.775.418-1.305.76-1.605-2.665-.304-5.466-1.335-5.466-5.93 0-1.31.468-2.382 1.236-3.22-.124-.303-.536-1.524.117-3.176 0 0 1.008-.322 3.3 1.23a11.52 11.52 0 0 1 3.003-.404c1.018.005 2.043.138 3.003.404 2.29-1.552 3.296-1.23 3.296-1.23.655 1.652.243 2.873.12 3.176.77.838 1.236 1.91 1.236 3.22 0 4.61-2.803 5.624-5.475 5.92.43.37.814 1.104.814 2.225 0 1.61-.015 2.91-.015 3.305 0 .322.216.698.825.58C20.565 21.796 24 17.298 24 12c0-6.63-5.37-12-12-12Z" />
      </svg>
    </a>
  </div>
</footer>

<script is:inline define:vars={{ apiUrl }}>
  const form = document.querySelector('#upload-form');
  const input = document.querySelector('#file-input');
  const dropZone = document.querySelector('#drop-zone');
  const fileSummary = document.querySelector('#file-summary');
  const submitButton = document.querySelector('#submit-button');
  const resetButton = document.querySelector('#reset-button');
  const clearButton = document.querySelector('#clear-button');
  const previewPanel = document.querySelector('#preview-panel');
  const previewList = document.querySelector('#preview-list');
  const loader = document.querySelector('#loader');
  const statusText = document.querySelector('#status-text');
  const emptyState = document.querySelector('#empty-state');
  const resultsGrid = document.querySelector('#results-grid');

  const resolvedApiUrl = apiUrl.startsWith('http')
    ? apiUrl
    : `${window.location.origin}${apiUrl}`;

  const MAX_FILES = 1;
  let selectedFiles = [];
  let previewUrls = [];
  let fileLimitMessage = '';

  const escapeHtml = (value) =>
    String(value)
      .replaceAll('&', '&amp;')
      .replaceAll('<', '&lt;')
      .replaceAll('>', '&gt;')
      .replaceAll('"', '&quot;')
      .replaceAll("'", '&#039;');

  const clearPreviewUrls = () => {
    previewUrls.forEach((url) => URL.revokeObjectURL(url));
    previewUrls = [];
  };

  const renderPreviews = () => {
    clearPreviewUrls();
    previewPanel.classList.toggle('hidden', selectedFiles.length === 0);

    previewList.innerHTML = selectedFiles
      .map((file, index) => {
        const url = URL.createObjectURL(file);
        previewUrls.push(url);

        return `
          <figure class="relative overflow-hidden rounded-[8px] border border-line bg-white">
            <button
              type="button"
              data-remove-preview="${index}"
              class="absolute right-1 top-1 grid h-6 w-6 place-items-center rounded-[8px] bg-white text-xs font-semibold text-slate-500 shadow-sm transition hover:text-accent"
              aria-label="Quitar imagen"
            >
              x
            </button>
            <img src="${url}" alt="${escapeHtml(file.name)}" class="h-20 w-full object-contain bg-white p-2" />
            <figcaption class="truncate border-t border-line px-2 py-1.5 text-xs text-slate-500">
              ${escapeHtml(file.name)}
            </figcaption>
          </figure>
        `;
      })
      .join('');
  };

  const updateSelectionState = () => {
    submitButton.disabled = selectedFiles.length === 0;
    fileSummary.textContent =
      fileLimitMessage ||
      (selectedFiles.length === 0
        ? 'Ningun archivo seleccionado.'
        : `${selectedFiles.length} imagen${selectedFiles.length === 1 ? '' : 'es'} lista${selectedFiles.length === 1 ? '' : 's'}.`);
    renderPreviews();
  };

  const setFiles = (files) => {
    const imageFiles = Array.from(files).filter((file) => file.type.startsWith('image/'));

    if (imageFiles.length > MAX_FILES) {
      selectedFiles = imageFiles.slice(0, MAX_FILES);
      fileLimitMessage = `Solo puedes subir una imagen para probar por ahora.`;
    } else {
      selectedFiles = imageFiles;
      fileLimitMessage = '';
    }

    updateSelectionState();
  };

  const clearSelection = () => {
    selectedFiles = [];
    input.value = '';
    updateSelectionState();
  };

  const resetAll = () => {
    clearSelection();
    resultsGrid.innerHTML = '';
    emptyState.classList.remove('hidden');
    statusText.textContent = 'Listo para analizar.';
    setLoading(false);
  };

  const setLoading = (isLoading) => {
    loader.classList.toggle('hidden', !isLoading);
    loader.classList.toggle('animate-spin', isLoading);
    submitButton.disabled = isLoading || selectedFiles.length === 0;
    submitButton.textContent = isLoading ? 'Analizando...' : 'Analizar';
  };

  const formatPercent = (value) => `${Math.round(Number(value) * 100)}%`;

  const renderResult = (result) => {
    const prediction = Number(result.prediction);
    const probabilities = result.probabilities
      .map((probability, digit) => ({ digit, probability: Number(probability) }))
      .sort((a, b) => b.probability - a.probability);

    return `
      <article class="rounded-[8px] border border-line bg-white p-5">
        <div class="grid gap-5 sm:grid-cols-[9rem_8rem_1fr] sm:items-center">
          <div class="rounded-[8px] border border-line bg-fog p-4">
            <p class="truncate text-xs font-medium text-slate-500">${escapeHtml(result.filename ?? 'Imagen')}</p>
            <div class="mt-4 flex items-end gap-3">
              <span class="text-7xl font-semibold leading-none text-ink">${prediction}</span>
              <span class="pb-2 text-base font-semibold text-accent">${formatPercent(result.confidence)}</span>
            </div>
          </div>

          <div class="rounded-[8px] border border-line bg-black p-3">
            <p class="mb-2 text-center text-xs font-semibold uppercase tracking-[0.16em] text-slate-300">Vista IA</p>
            <img
              src="${result.processedImage}"
              alt="Imagen procesada para MNIST"
              class="mx-auto h-24 w-24 object-contain [image-rendering:pixelated]"
            />
            <p class="mt-2 truncate text-center text-[10px] text-slate-400">${escapeHtml(result.preprocessing ?? '')}</p>
          </div>

          <div class="space-y-2.5">
            ${probabilities
              .map(
                ({ digit, probability }) => `
                  <div class="grid grid-cols-[1.5rem_1fr_2.75rem] items-center gap-3">
                    <span class="text-sm font-semibold ${digit === prediction ? 'text-ink' : 'text-slate-400'}">${digit}</span>
                    <div class="h-2 overflow-hidden rounded-full bg-slate-100">
                      <div
                        class="h-full rounded-full ${digit === prediction ? 'bg-accent' : 'bg-mint'}"
                        style="width: ${Math.max(probability * 100, 1)}%"
                      ></div>
                    </div>
                    <span class="text-right text-xs tabular-nums text-slate-500">${formatPercent(probability)}</span>
                  </div>
                `
              )
              .join('')}
          </div>
        </div>
      </article>
    `;
  };

  input.addEventListener('change', (event) => {
    setFiles(event.target.files);
  });

  ['dragenter', 'dragover'].forEach((eventName) => {
    dropZone.addEventListener(eventName, (event) => {
      event.preventDefault();
      dropZone.classList.add('border-accent', 'bg-white');
    });
  });

  ['dragleave', 'drop'].forEach((eventName) => {
    dropZone.addEventListener(eventName, (event) => {
      event.preventDefault();
      dropZone.classList.remove('border-accent', 'bg-white');
    });
  });

  dropZone.addEventListener('drop', (event) => {
    setFiles(event.dataTransfer.files);
  });

  previewList.addEventListener('click', (event) => {
    const button = event.target.closest('[data-remove-preview]');

    if (!button) {
      return;
    }

    const index = Number(button.dataset.removePreview);
    selectedFiles.splice(index, 1);
    input.value = '';
    updateSelectionState();
  });

  clearButton.addEventListener('click', clearSelection);
  resetButton.addEventListener('click', resetAll);

  form.addEventListener('submit', async (event) => {
    event.preventDefault();

    if (selectedFiles.length === 0) {
      return;
    }

    const formData = new FormData();
    selectedFiles.forEach((file) => formData.append('files', file));

    setLoading(true);
    statusText.textContent = 'Procesando imagen...';
    emptyState.classList.add('hidden');
    resultsGrid.innerHTML = '';

    try {
      const response = await fetch(resolvedApiUrl, {
        method: 'POST',
        body: formData,
      });

      const rawResponseText = await response.text();
      let payload;
      let errorText = rawResponseText;

      try {
        payload = rawResponseText ? JSON.parse(rawResponseText) : {};
      } catch {
        payload = undefined;
      }

      if (!response.ok) {
        throw new Error(
          (payload?.detail ?? errorText) || 'La respuesta del servidor no es un JSON válido.'
        );
      }

      const results = payload.results ?? [payload];
      resultsGrid.innerHTML = results.map(renderResult).join('');
      statusText.textContent = `${results.length} resultado${results.length === 1 ? '' : 's'} generado${results.length === 1 ? '' : 's'}.`;
    } catch (error) {
      emptyState.classList.remove('hidden');
      statusText.textContent = error instanceof Error ? error.message : 'Ocurrio un error inesperado.';
    } finally {
      setLoading(false);
    }
  });
</script>
